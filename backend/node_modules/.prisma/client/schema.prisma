// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  password    String
  fullName    String
  role        String          @default("business_owner")
  memberships CompanyMember[]
  companies   Company[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Company {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  gstNumber      String?              @unique
  companyName    String
  state          String
  pan            String?
  employeesCount Int?
  businessType   String?
  members        CompanyMember[]
  invoices       Invoice[]
  gstReturns     GSTReturn[]
  tdsRecords     TDSRecord[]
  tdsReturns     TDSReturn[]
  deadlines      ComplianceDeadline[]
  tasks          ComplianceTask[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNumber String
  vendorName    String
  vendorGst     String?
  amount        Decimal  @db.Decimal(15, 2)
  gstRate       Int
  sgst          Decimal  @db.Decimal(15, 2)
  cgst          Decimal  @db.Decimal(15, 2)
  igst          Decimal  @db.Decimal(15, 2)
  totalTax      Decimal  @db.Decimal(15, 2)
  invoiceDate   DateTime
  invoiceType   String
  state         String
  hsnCode       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([invoiceDate])
}

model GSTReturn {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  month             Int
  year              Int
  gstr1Status       String    @default("draft")
  gstr3bStatus      String    @default("draft")
  gstr1FiledDate    DateTime?
  gstr3bFiledDate   DateTime?
  totalSales        Decimal   @db.Decimal(15, 2)
  totalTaxLiability Decimal   @db.Decimal(15, 2)
  inputCredit       Decimal   @default(0) @db.Decimal(15, 2)
  netPayable        Decimal   @db.Decimal(15, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([companyId, month, year])
  @@index([companyId])
}

model TDSRecord {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorName    String
  vendorPan     String?
  paymentDate   DateTime
  paymentAmount Decimal  @db.Decimal(15, 2)
  tdsRate       Int
  tdsDeducted   Decimal  @db.Decimal(15, 2)
  paymentMade   Decimal  @db.Decimal(15, 2)
  category      String
  quarter       Int
  year          Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([quarter, year])
}

model TDSReturn {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quarter           Int
  year              Int
  totalPayments     Decimal   @db.Decimal(15, 2)
  totalTdsDeducted  Decimal   @db.Decimal(15, 2)
  totalTdsDeposited Decimal   @db.Decimal(15, 2)
  filingStatus      String    @default("draft")
  filedDate         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([companyId, quarter, year])
  @@index([companyId])
}

model ComplianceDeadline {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  complianceType String
  dueDate        DateTime
  description    String
  status         String    @default("pending")
  completedDate  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@index([dueDate])
}

model ComplianceTask {
  id        String   @id @default(cuid())
  companyId String
  type      String // 'GST Filing', 'GST Payment', 'TDS Return', 'TDS Payment'
  desc      String
  date      DateTime // Due date
  color     String
  status    String   @default("pending") // 'pending', 'in_progress', 'completed'
  month     Int?
  year      Int?
  quarter   Int?

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyMember {
  id        String @id @default(cuid())
  userId    String
  companyId String
  role      String @default("VIEWER") // OWNER, ADMIN, EDITOR, VIEWER
  status    String @default("PENDING") // PENDING, ACTIVE

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // A user can only hold one role per company
  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}
